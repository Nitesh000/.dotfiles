# By default Reload config with shft + cmd + , 

theme = Rose Pine Moon
background = #000000
background-opacity = 0.65
background-blur-radius = 20

font-family = MesloLGLDZ Nerd Font
font-family-bold = MesloLGLDZ Nerd Font
font-family-italic = MesloLGLDZ Nerd Font
font-family-bold-italic = MesloLGLDZ Nerd Font
font-size = 14
font-thicken = true
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor 

macos-titlebar-style = hidden

confirm-close-surface = false
window-decoration = true
window-padding-x = 5
window-padding-y = 5
window-padding-balance = true

auto-update = check

quit-after-last-window-closed = true

# Custom Keybinds & Config (super represents cmd key on mac)

# For Simple Keybinds
keybind = super+r=reload_config 
keybind = super+i=inspector:toggle

# Similar Tmux but with Ghostty
# (ctrl b for tmux -> cmb b for ghostty)
keybind = super+b>r=reload_config
keybind = super+b>x=close_surface
# this only works if you have `macos-titlebar-style = tabs or native or transparent`
# else it behaves like new window
keybind = super+b>c=new_tab 
keybind = super+b>n=new_window

# tab nav
keybind = super+b>1=goto_tab:1
keybind = super+b>2=goto_tab:2
keybind = super+b>3=goto_tab:3
keybind = super+b>4=goto_tab:4
keybind = super+b>5=goto_tab:5
keybind = super+b>6=goto_tab:6
keybind = super+b>7=goto_tab:7
keybind = super+b>8=goto_tab:8
keybind = super+b>9=goto_tab:9

# splitting
# | current does not work
keybind = super+b>\=new_split:right
keybind = super+b>-=new_split:down
keybind = super+b>e=equalize_splits

# split nav
keybind = super+b>h=goto_split:left
keybind = super+b>j=goto_split:bottom
keybind = super+b>k=goto_split:top
keybind = super+b>l=goto_split:right


# quick terminal
# quick-terminal-screen = mouse
# quick-terminal-position = left
# keybind = super+b>t=toggle_quick_terminal

# disable keybinds related to d
keybind = d=unbind

# colors 
# Primary colors
background = 000000
foreground = ffffff

# Cursor
cursor-color = ffffff
cursor-text = F81CE5

# Normal colors (palette 0-7)
palette = 0=#000000
palette = 1=#fe0100
palette = 2=#33ff00
palette = 3=#feff00
palette = 4=#0066ff
palette = 5=#cc00ff
palette = 6=#00ffff
palette = 7=#d0d0d0

# Bright colors (palette 8-15)
palette = 8=#808080
palette = 9=#fe0100
palette = 10=#33ff00
palette = 11=#feff00
palette = 12=#0066ff
palette = 13=#cc00ff
palette = 14=#00ffff
palette = 15=#ffffff


